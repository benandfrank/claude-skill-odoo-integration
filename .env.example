# Odoo connection
ODOO_HOST=erp.example.com
ODOO_DATABASE=production_db
ODOO_LOGIN=sync_user@example.com
ODOO_PASSWORD=replace_me
ODOO_PROTOCOL=https
ODOO_PORT=443

# Sync policy
SYNC_MODE=append
SYNC_PAGE_SIZE=500
SYNC_MODEL=stock.picking
SYNC_CHECKPOINT_FIELD=write_date
SYNC_ORDER=write_date asc,id asc
SYNC_IDEMPOTENCY_KEY=id

# Runtime / scheduling
LOG_LEVEL=info
RUN_TIMEOUT_SECONDS=300
ENABLE_METRICS=true

# Checkpoint / lock backends
CHECKPOINT_BACKEND=sqlite
LOCK_BACKEND=memory
CHECKPOINT_SQLITE_PATH=./var/checkpoints.db

# Output sink
OUTPUT_SINK=google-sheets

# Google Sheets example
GOOGLE_SHEETS_ID=replace_me
GOOGLE_SHEET_NAME=April 2026
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"replace_me"}

# Postgres example
POSTGRES_URL=postgres://user:password@localhost:5432/odoo_sync

# Notes
# - Keep real secrets out of git
# - Prefer checkpoint storage outside Google Sheets
# - If using HTTP locally, set ODOO_PROTOCOL=http and ODOO_PORT=8069
